<Window x:Class="SessionFlow.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="SessionFlow"
        Icon="logo.png"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#020617">

    <Grid>
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="SessionFlow"
                        DoubleClickCommand="{x:Static SystemCommands.RestoreWindowCommand}"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open SessionFlow" Click="TrayOpen_Click" FontWeight="Bold" />
                    <MenuItem Header="Today's Sessions" Click="TrayTodaySessions_Click" />
                    <Separator />
                    <MenuItem Header="Quit" Click="TrayQuit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- WebView2 fills entire client area -->
        <wv2:WebView2 x:Name="WebView"
                      DefaultBackgroundColor="#020617" />
    </Grid>
</Window>
