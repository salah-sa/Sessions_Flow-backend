# SessionFlow Secrets — Template
# Copy to .env and fill in real values. NEVER commit the .env file.

# MongoDB connection string (required)
SESSIONFLOW_DB_CONNECTION="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/"

# JWT signing key (auto-generated on first run if empty)
SESSIONFLOW_JWT_SECRET=""

# Default admin password for seeding (auto-generated on first run if empty)
SESSIONFLOW_ADMIN_PASSWORD=""

# Redis connection (optional — defaults to localhost:6379)
# SESSIONFLOW_REDIS_CONNECTION="localhost:6379"

# CORS allowed origins for production (comma-separated)
# CORS_ALLOWED_ORIGINS="https://your-domain.com,https://api.your-domain.com"

# Gmail SMTP — required for OTP/Wallet email delivery on Railway
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER="your-gmail@gmail.com"
GMAIL_SMTP_APP_PASSWORD="abcdefghijklmnop"

# Resend API — verified domain: sessionflow.uk (sends to any address)
# Free tier: 100 emails/day, 3000/month. Upgrade plan for higher volume.
# RESEND_API_KEY="re_xxxxxxxxxxxx"
# RESEND_FROM="SessionFlow <noreply@sessionflow.uk>"

# ── AI Provider (Groq — 100% FREE, no credit card) ──────────────────────────
# 1. Sign up at https://console.groq.com (free, no card required)
# 2. Create API Key → copy it here
# 3. Model: llama-3.3-70b-versatile (default, strongest free model)
# Free tier: ~30 RPM, ~14,400 RPD — more than enough for production SaaS.
GROQ_API_KEY="gsk_xxxxxxxxxxxx"
# GROQ_MODEL="llama-3.3-70b-versatile"

# ── AI Provider (OpenAI — paid alternative, optional) ────────────────────────
# Only needed if you prefer GPT-4o over Groq. Requires billing.
# AI__OpenAiApiKey="sk-xxxxxxxxxxxx"
# AI__Model="gpt-4o-mini"
